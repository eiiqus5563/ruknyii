  @@unique([formId, date, country, city])
  @@index([date])
  @@index([formId])
}

model form_steps {
  id          String      @id
  formId      String
  title       String
  description String?
  order       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  form_fields FormField[]
  forms       Form        @relation(fields: [formId], references: [id], onDelete: Cascade)

