}

/// 💰 نوع معاملة المحفظة
enum WalletTransactionType {
  TOP_UP            /// شحن رصيد
  MESSAGE_CHARGE    /// خصم رسالة
  REFUND            /// استرداد
  AUTO_RECHARGE     /// شحن تلقائي
  ADJUSTMENT        /// تعديل يدوي (من الإدارة)
  APP_ALLOCATION    /// تحويل من المحفظة الرئيسية إلى التطبيق
}

/// 💰 محفظة المطوّر
model DeveloperWallet {
  id                    String          @id @default(uuid())
  userId                String          @unique
  balance               Int             @default(0) /// الرصيد بالدينار العراقي (IQD)
  currency              String          @default("IQD")
  autoRechargeEnabled   Boolean         @default(false)
  autoRechargeAmount    Int?            /// مبلغ الشحن التلقائي
  autoRechargeThreshold Int?            /// الحد الأدنى لتفعيل الشحن التلقائي
  lowBalanceAlert       Int?            /// تنبيه انخفاض الرصيد
  totalTopUps           Int             @default(0) /// إجمالي الشحن
  totalSpent            Int             @default(0) /// إجمالي الإنفاق
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation("developer_wallet", fields: [userId], references: [id], onDelete: Cascade)
  transactions          WalletTransaction[]

  @@index([userId])
  @@index([balance])
  @@map("developer_wallets")
}

/// 💰 معاملة محفظة
model WalletTransaction {
  id              String                   @id @default(uuid())
  walletId        String
  type            WalletTransactionType
  amount          Int                      /// المبلغ (موجب دائماً)
  balanceBefore   Int                      /// الرصيد قبل العملية
  balanceAfter    Int                      /// الرصيد بعد العملية
  status          WalletTransactionStatus  @default(PENDING)
  description     String?
  referenceId     String?                  /// messageLogId أو paymentId
  referenceType   String?                  /// "message" | "payment" | "admin"
  paymentMethod   String?                  /// "zaincash" | "fastpay" | "card" (للشحن فقط)
  externalId      String?                  /// معرّف من بوابة الدفع
  metadata        Json?
  createdAt       DateTime                 @default(now())

  wallet          DeveloperWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([referenceId])
  @@map("wallet_transactions")
}
