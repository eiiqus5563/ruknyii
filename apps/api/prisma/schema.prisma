  environment     String       @default("live") /// "live" | "test"
  status          ApiKeyStatus @default(ACTIVE)
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  ipAllowlist     String[]     @default([])
  requestCount    BigInt       @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  developerApp    DeveloperApp? @relation(fields: [developerAppId], references: [id], onDelete: Cascade)
  messageLogs     WhatsappMessageLog[]
  apiRequestLogs  ApiRequestLog[]

  @@index([keyHash])
  @@index([userId])
  @@index([developerAppId])
  @@index([status])
  @@index([slug])
  @@map("developer_api_keys")
}

