  EXPIRED
}

/// 🔑 مفتاح API للمطوّر
model DeveloperApiKey {
  id              String       @id @default(uuid())
  slug            String       @unique /// معرّف قصير من 6 أرقام للعرض في الروابط
  userId          String
  developerAppId  String?      /// مرتبط بتطبيق محدد (اختياري للتوافق الخلفي)
